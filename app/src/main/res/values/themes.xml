<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.TriSandhya" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/accent</item>
        <item name="colorPrimaryVariant">@color/accent_dark</item>
        <item name="colorOnPrimary">@color/text_primary</item>

        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/sunrise_color</item>
        <item name="colorSecondaryVariant">@color/sunset_color</item>
        <item name="colorOnSecondary">@color/bg_deep</item>

        <!-- Background -->
        <item name="android:windowBackground">@color/bg_deep</item>
        <item name="android:statusBarColor">@color/bg_deep</item>
        <item name="android:navigationBarColor">@color/bg_deep</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Surface -->
        <item name="colorSurface">@color/card_bg</item>
        <item name="colorOnSurface">@color/text_primary</item>

        <!-- Error -->
        <item name="colorError">#FF6B6B</item>
        <item name="colorOnError">@color/bg_deep</item>
    </style>

</resources>
